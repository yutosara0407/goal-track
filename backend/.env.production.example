APP_NAME=GoalTrack
APP_ENV=production
APP_KEY=base64:ここにkey:generateで生成した値を入れる
APP_DEBUG=false
APP_URL=https://your-tunnel-domain.trycloudflare.com

APP_LOCALE=ja
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/state/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file

FRONTEND_URL=https://your-tunnel-domain.trycloudflare.com

HASH_DRIVER=argon2id
