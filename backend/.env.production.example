APP_NAME=GoalTrack
APP_ENV=production
APP_KEY=base64:ここにkey:generateで生成した値を入れる
APP_DEBUG=false
APP_URL=https://your-tunnel-domain.trycloudflare.com

APP_LOCALE=ja
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/state/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file

FRONTEND_URL=https://your-tunnel-domain.trycloudflare.com

HASH_DRIVER=argon2id

# メール送信設定（パスワード再設定メールなどに使用）
# 本番でメールを実際に届けるにはSMTPを設定する（例: Gmailのアプリパスワード、Resend、SendGridなど）
# 未設定（log）の場合、メールは送信されず storage/logs/laravel.log に内容が出力される
MAIL_MAILER=log
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="${APP_NAME}"
